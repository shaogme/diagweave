{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shaogme/diagweave/schemas/report-otel-v0.1.0.schema.json",
  "title": "diagweave OTEL Envelope v0.1.0",
  "$defs": {
    "trace_id": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{32}$"
    },
    "span_id": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{16}$"
    },
    "severity_number": {
      "type": "integer",
      "enum": [1, 5, 9, 13, 17, 21]
    },
    "otel_attribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string" },
        "value": { "$ref": "#/$defs/otel_value" }
      }
    },
    "otel_value": {
      "oneOf": [
        {
          "type": "string",
          "const": "Null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["String"],
          "properties": {
            "String": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["Int"],
          "properties": {
            "Int": { "type": "integer" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["U64"],
          "properties": {
            "U64": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["Double"],
          "properties": {
            "Double": { "type": "number" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["Bool"],
          "properties": {
            "Bool": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["Bytes"],
          "properties": {
            "Bytes": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0, "maximum": 255 }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["Array"],
          "properties": {
            "Array": {
              "type": "array",
              "items": { "$ref": "#/$defs/otel_value" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["KvList"],
          "properties": {
            "KvList": {
              "type": "array",
              "items": { "$ref": "#/$defs/otel_attribute" }
            }
          }
        }
      ]
    },
    "otel_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "body",
        "timestamp_unix_nano",
        "observed_timestamp_unix_nano",
        "severity_text",
        "severity_number",
        "trace_id",
        "span_id",
        "trace_flags",
        "attributes"
      ],
      "properties": {
        "name": { "type": "string" },
        "body": {
          "description": "Structured error node for the primary exception record, or null for trace-event records.",
          "oneOf": [
            { "$ref": "#/$defs/otel_value" },
            { "type": "null" }
          ]
        },
        "timestamp_unix_nano": { "type": ["integer", "null"], "minimum": 0 },
        "observed_timestamp_unix_nano": { "type": ["integer", "null"], "minimum": 0 },
        "severity_text": { "type": ["string", "null"] },
        "severity_number": {
          "oneOf": [
            { "$ref": "#/$defs/severity_number" },
            { "type": "null" }
          ]
        },
        "trace_id": {
          "oneOf": [
            { "$ref": "#/$defs/trace_id" },
            { "type": "null" }
          ]
        },
        "span_id": {
          "oneOf": [
            { "$ref": "#/$defs/span_id" },
            { "type": "null" }
          ]
        },
        "trace_flags": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 255
        },
        "attributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/otel_attribute" }
        }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["records"],
  "properties": {
    "records": {
      "type": "array",
      "items": { "$ref": "#/$defs/otel_event" }
    }
  }
}
